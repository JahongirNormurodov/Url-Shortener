# Ilova sozlamalari namunasi. Nusxa oling: cp .env.example .env
# .env faylini git'ga QO'SHMANG (maxfiy kalitlar bo'ladi).

# --- Umumiy ---
APP_NAME=url-shortener
ENVIRONMENT=development
# Qisqa havola prefiksi (short_url shu asosda quriladi).
BASE_URL=http://localhost:8000

# --- Database ---
# Production (Postgres):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urlshortener
# Lokal tez sinov uchun (Postgres'siz) SQLite ham ishlaydi:
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# --- Redis (keyingi fazalarda: kesh, rate-limit, click bufer) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT / Auth ---
# MUHIM: productionда uzun, tasodifiy maxfiy kalit qo'ying (>= 32 bayt)!
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- URL tekshirish ---
# SSRF himoyasida domenni DNS orqali tekshirish (offlayn/test'da false).
URL_RESOLVE_DNS=true
